# Vita AI – environment variables (copy to .env and fill in)

# Comma-separated list of allowed CORS origins (default: "*")
CORS_ORIGINS=*

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ── Model auto-download & cache ──────────────────────────────────────────
# Set to "false" to disable automatic downloading of supported models
VITA_AUTO_DOWNLOAD_MODELS=true

# Set to "true" to preload all models at server startup
VITA_PRELOAD_MODELS=false

# ── Enable/disable individual auto-downloadable models ───────────────────
VITA_ENABLE_DISTILBERT=true
VITA_ENABLE_BIOBERT=true
VITA_ENABLE_YAMNET=true

# ── Manual model paths (only needed for plug-in models) ──────────────────
# VITA_TSCAN_MODEL_PATH=/path/to/tscan_weights.pth
# VITA_PHYSNET_MODEL_PATH=/path/to/physnet_weights.pth
# VITA_DEEPPHYS_MODEL_PATH=/path/to/deepphys_weights.pth
# VITA_VGGISH_MODEL_PATH=/path/to/vggish_weights.pth  # or "torchvggish"
# VITA_YAMNET_MODEL_PATH=/path/to/yamnet_saved_model/  # override auto-download
# VITA_BIOBERT_MODEL=dmis-lab/biobert-base-cased-v1.1  # override HF model ID
# VITA_FUSION_MODEL_PATH=/path/to/fusion_model.json
