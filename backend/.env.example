# ===========================================================================
# Vita AI Backend – Environment Configuration
# ===========================================================================
# Copy this file to .env and adjust values for your environment.
# All variables have sensible defaults for local development.

# ── Server ────────────────────────────────────────────────────────────────

# CORS origins (comma-separated). Use "*" for development only.
# Example for production: "https://vita-ai.example.com,https://api.vita-ai.example.com"
CORS_ORIGINS=*

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Authentication (JWT) ─────────────────────────────────────────────────
# Code integrated from Manogna — JWT secret for token signing.
# IMPORTANT: Change this in production!
VITA_JWT_SECRET=vita-ai-dev-secret-change-in-production

# ── Encryption ───────────────────────────────────────────────────────────
# Security/encryption logic adapted from Manogna's backend.
# Fernet key for field-level encryption of PII (phone numbers, etc.).
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, a random key is generated at startup (data won't survive restarts).
# VITA_ENCRYPTION_KEY=your-fernet-key-here

# ── Model Control ────────────────────────────────────────────────────────
VITA_AUTO_DOWNLOAD_MODELS=true
VITA_PRELOAD_MODELS=true
VITA_ENABLE_DISTILBERT=true
VITA_ENABLE_BIOBERT=true
VITA_ENABLE_YAMNET=true
VITA_ENABLE_OPEN_RPPG=true
VITA_OPEN_RPPG_MODEL=FacePhys.rlap

# ── WebSocket Streaming ──────────────────────────────────────────────────
VITA_MAX_STREAMS=10

# ── OAuth (Google / Facebook / Apple) ───────────────────────────────────
# Set frontend URL so backend can redirect with token/error query params.
# Local single-host setup: http://localhost:8000
VITA_FRONTEND_URL=http://localhost:8000

# Enable extra OAuth diagnostics in backend logs (redacts secrets/tokens).
VITA_OAUTH_DEBUG=true

# Google OAuth
VITA_GOOGLE_CLIENT_ID=
VITA_GOOGLE_CLIENT_SECRET=
VITA_GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback

# Facebook OAuth
VITA_FACEBOOK_CLIENT_ID=
VITA_FACEBOOK_CLIENT_SECRET=
VITA_FACEBOOK_REDIRECT_URI=http://localhost:8000/auth/oauth/facebook/callback

# Apple OAuth
VITA_APPLE_CLIENT_ID=
VITA_APPLE_TEAM_ID=
VITA_APPLE_KEY_ID=
# Put private key as a single-line string with escaped newlines (\n)
VITA_APPLE_PRIVATE_KEY=
VITA_APPLE_REDIRECT_URI=http://localhost:8000/auth/oauth/apple/callback
